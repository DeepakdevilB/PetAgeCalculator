---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page Not Found — MyPetAgeCalc">
  <Navbar />
  
  <main class="relative bg-canvas min-h-[80vh] flex flex-col items-center justify-center text-center overflow-hidden py-32">
    <!-- Mesh Gradient Backdrop -->
    <div class="absolute inset-0 mesh-gradient opacity-40 pointer-events-none" aria-hidden="true"></div>
    
    <!-- Subtle grid pattern overlay -->
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none" aria-hidden="true"
      style="background-image: linear-gradient(rgba(0,0,0,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.1) 1px, transparent 1px); background-size: 64px 64px;">
    </div>

    <div class="relative page-container max-w-[600px] mx-auto z-10">
      <span class="display-xl text-primary block mb-4" style="font-size: 100px; line-height: 1;">404</span>
      <h1 class="display-md text-ink mb-4">Oops! You chased a bad link.</h1>
      
      <p class="body-lg text-body mb-10">
        We couldn't find the page you're looking for. It might have been moved, deleted, or perhaps it never existed in the first place.
      </p>

      <a
        href="/"
        class="inline-flex items-center justify-center bg-primary text-on-primary button-text-lg rounded-pill px-10 h-14 no-underline transition-all duration-200 hover:opacity-90 hover:scale-[1.02] active:scale-[0.98] shadow-level-2"
      >
        Return to Home
      </a>
    </div>
  </main>

  <Footer />
</Layout>
