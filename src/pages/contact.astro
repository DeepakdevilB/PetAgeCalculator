---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact Us — Pet Age Calculator">
  <Navbar />
  
  <main class="bg-canvas min-h-screen pt-32 pb-20">
    <div class="page-container max-w-[800px] mx-auto">
      <h1 class="display-xl text-ink mb-6">Contact Us</h1>
      
      <div class="flex flex-col gap-6 body-lg text-body">
        <p>
          We'd love to hear from you! Whether you have a question about our age calculator, feedback on how we can improve, or just want to share a cute picture of your pet, our team is here for you.
        </p>

        <div class="bg-canvas-soft border border-hairline rounded-lg p-8 mt-6">
          <h2 class="display-sm text-ink mb-2">Get in Touch</h2>
          <p class="body-md text-mute mb-8">
            The fastest way to reach us is via email. We typically respond within 24-48 hours.
          </p>

          <div class="flex flex-col gap-4">
            <div class="flex items-center gap-3">
              <span class="text-2xl">✉️</span>
              <div>
                <strong class="block text-ink body-sm-strong">General Inquiries & Support</strong>
                <a href="mailto:agencybyds@gmail.com" class="text-link hover:underline">agencybyds@gmail.com</a>
              </div>
            </div>
            
            <div class="flex items-center gap-3 mt-4">
              <span class="text-2xl">🤝</span>
              <div>
                <strong class="block text-ink body-sm-strong">Partnerships & Media</strong>
                <a href="mailto:deep.pgl.work@gmail.com" class="text-link hover:underline">deep.pgl.work@gmail.com</a>
              </div>
            </div>
          </div>
        </div>

        <h2 class="display-sm text-ink mt-8 mb-4">A Note on Veterinary Advice</h2>
        <p class="bg-canvas-soft-2 p-6 rounded-md border-l-4 border-primary text-body body-md">
          <strong>Important:</strong> PetAgeCalc is an informational tool only. We do not employ veterinarians and cannot provide medical advice for your pet. If your pet is experiencing a medical emergency, please contact your local emergency veterinary clinic immediately.
        </p>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
