---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout 
  title="Pet Advice & Articles - PetAgeCalc" 
  description="Expert pet advice, articles, and guides on understanding your dog or cat's true age and keeping them healthy."
>
  <Navbar />
  
  <main class="pt-32 pb-20 min-h-screen">
    <div class="max-w-[80rem] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-[48rem] mx-auto mb-16 text-center">
        <h1 class="display-xl display-xl-responsive text-ink mb-6 tracking-tight">Pet <span class="text-transparent bg-clip-text bg-[linear-gradient(90deg,var(--color-link),var(--color-cyan))]">Advice</span></h1>
        <p class="text-lg text-mute max-w-[42rem] mx-auto px-4">Expert articles and guides on understanding your pet's true age, health, and how to maximize your time together.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-[72rem] mx-auto">
        {posts.map((post) => (
          <a href={`/pet-advice/${post.id}`} class="group flex flex-col bg-canvas border border-hairline rounded-lg overflow-hidden shadow-level-1 hover:shadow-level-3 hover:border-hairline-strong transition-all duration-300 hover:-translate-y-1 no-underline">
            <div class="p-6 md:p-8 flex flex-col h-full">
              <div class="flex items-center gap-2 mb-4">
                {post.data.tags.map((tag: string) => (
                  <span class="caption-mono bg-canvas-soft-2 text-ink px-2 py-1 rounded-sm">{tag}</span>
                ))}
              </div>
              <h2 class="text-xl font-semibold text-ink mb-3 group-hover:text-link transition-colors">{post.data.title}</h2>
              <p class="body-sm text-mute line-clamp-3 mb-6 flex-1">{post.data.description}</p>
              
              <div class="flex items-center justify-between mt-auto pt-4 border-t border-hairline">
                <span class="caption-text text-body">{post.data.author}</span>
                <span class="caption-text text-mute">{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>
