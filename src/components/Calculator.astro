---
interface Props {
  type?: 'dog' | 'cat' | 'both';
  hideHeader?: boolean;
}

const { type = 'both', hideHeader = false } = Astro.props;

const isDogOnly = type === 'dog';
const isCatOnly = type === 'cat';
---

<section id="calculator" class="bg-canvas-soft py-20 md:py-28">
  <div class="page-container">
    <!-- Section Eyebrow -->
    {!hideHeader && (
      <div class="text-center mb-12">
        <span class="caption-mono text-mute block mb-3">Pet Age Calculator</span>
        <h2 class="display-lg display-lg-responsive text-ink">Calculate your {type === 'dog' ? 'dog' : type === 'cat' ? 'cat' : 'pet'}'s real age.</h2>
      </div>
    )}

    <!-- Calculator Card -->
    <div class="max-w-[42rem] mx-auto bg-canvas rounded-lg shadow-level-4 overflow-hidden" id="calculator-card" data-type={type}>
      <!-- Calculator Form -->
      <div class="p-6 md:p-8 lg:p-10">
        <!-- Pet Type Toggle -->
        {type === 'both' && (
          <div class="mb-8" id="pet-type-container">
            <label class="text-base font-semibold text-ink block mb-3">Choose your pet</label>
            <div class="flex bg-canvas-soft-2 rounded-pill-sm p-1 gap-1" role="tablist" id="pet-type-tabs">
              <button
                role="tab"
                id="tab-dog"
                aria-selected="true"
                class="pet-tab flex-1 flex items-center justify-center gap-2 body-sm-strong rounded-pill-sm h-12 transition-all duration-200 bg-canvas text-ink shadow-level-1"
                data-pet="dog"
              >
                <span class="text-lg">🐕</span>
                Dog
              </button>
              <button
                role="tab"
                id="tab-cat"
                aria-selected="false"
                class="pet-tab flex-1 flex items-center justify-center gap-2 body-sm-strong rounded-pill-sm h-12 transition-all duration-200 text-body hover:text-ink"
                data-pet="cat"
              >
                <span class="text-lg">🐈</span>
                Cat
              </button>
            </div>
          </div>
        )}

        <!-- Age Input -->
        <div class="mb-8">
          <label class="text-base font-semibold text-ink block mb-3">Pet's age</label>
          <div class="flex gap-3">
            <div class="flex-1">
              <label for="age-years" class="body-sm text-mute block mb-1.5">Years</label>
              <div class="relative">
                <input
                  type="number"
                  id="age-years"
                  min="0"
                  max="25"
                  value="3"
                  class="w-full h-14 bg-canvas border border-hairline rounded-sm px-4 body-md text-ink outline-none focus:border-link focus:ring-1 focus:ring-link transition-all"
                />
              </div>
            </div>
            <div class="flex-1">
              <label for="age-months" class="body-sm text-mute block mb-1.5">Months</label>
              <select
                id="age-months"
                class="w-full h-14 bg-canvas border border-hairline rounded-sm px-4 body-md text-ink outline-none focus:border-link focus:ring-1 focus:ring-link transition-all appearance-none cursor-pointer"
              >
                <option value="0">0</option>
                <option value="1">1</option>
                <option value="2">2</option>
                <option value="3">3</option>
                <option value="4">4</option>
                <option value="5">5</option>
                <option value="6">6</option>
                <option value="7">7</option>
                <option value="8">8</option>
                <option value="9">9</option>
                <option value="10">10</option>
                <option value="11">11</option>
              </select>
            </div>
          </div>
          <p class="body-sm text-mute mt-2">Not sure? Give your best guess!</p>
        </div>

        <!-- Dog Breed / Size (shown for dogs) -->
        <div id="dog-size-group" class={`mb-8 ${isCatOnly ? 'hidden' : ''}`}>
          <label for="breed-search" class="text-base font-semibold text-ink block mb-3">Dog breed</label>
          
          <!-- Breed Search Combobox -->
          <div class="relative mb-4" id="breed-selector-group">
            <div class="relative">
              <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-mute pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
              <input
                type="text"
                id="breed-search"
                placeholder="Search breeds (e.g. Golden Retriever)..."
                class="w-full h-14 bg-canvas border border-hairline rounded-sm pl-12 pr-10 body-md text-ink outline-none focus:border-link focus:ring-1 focus:ring-link transition-all"
                autocomplete="off"
              />
              <!-- Clear button -->
              <button id="breed-clear" class="absolute right-3 top-1/2 -translate-y-1/2 w-5 h-5 text-mute hover:text-ink hidden cursor-pointer" aria-label="Clear breed">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
            
            <!-- Dropdown List -->
            <ul id="breed-dropdown" class="absolute z-20 w-full mt-1 max-h-60 overflow-y-auto bg-canvas border border-hairline rounded-md shadow-level-3 hidden">
              <!-- Populated by JS -->
            </ul>
          </div>

          <!-- Fallback Size Selection -->
          <div id="dog-size-fallback" class="animate-fade-in">
            <label class="text-base font-semibold text-ink block mb-3">Estimated adult size</label>
            <div class="grid grid-cols-2 sm:grid-cols-5 gap-x-2 gap-y-4" id="dog-size-options">
              <!-- Toy -->
              <div class="flex flex-col gap-1">
                <button class="size-btn w-full body-md rounded-sm h-12 border border-hairline bg-canvas text-body hover:border-hairline-strong transition-all" data-size="toy">Toy</button>
                <span class="body-sm text-mute text-center">&lt;10 lbs</span>
              </div>
              
              <!-- Small -->
              <div class="flex flex-col gap-1">
                <button class="size-btn w-full body-md rounded-sm h-12 border border-primary bg-primary text-on-primary transition-all" data-size="small">Small</button>
                <span class="body-sm text-mute text-center">10-25 lbs</span>
              </div>

              <!-- Medium -->
              <div class="flex flex-col gap-1">
                <button class="size-btn w-full body-md rounded-sm h-12 border border-hairline bg-canvas text-body hover:border-hairline-strong transition-all" data-size="medium">Medium</button>
                <span class="body-sm text-mute text-center">25-50 lbs</span>
              </div>

              <!-- Large -->
              <div class="flex flex-col gap-1">
                <button class="size-btn w-full body-md rounded-sm h-12 border border-hairline bg-canvas text-body hover:border-hairline-strong transition-all" data-size="large">Large</button>
                <span class="body-sm text-mute text-center">50-100 lbs</span>
              </div>

              <!-- Giant -->
              <div class="flex flex-col gap-1 col-span-2 sm:col-span-1">
                <button class="size-btn w-full body-md rounded-sm h-12 border border-hairline bg-canvas text-body hover:border-hairline-strong transition-all" data-size="giant">Giant</button>
                <span class="body-sm text-mute text-center">100+ lbs</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Cat Type (shown for cats, hidden by default unless type is cat) -->
        <div id="cat-type-group" class={`mb-8 ${!isCatOnly ? 'hidden' : ''}`}>
          <label class="text-base font-semibold text-ink block mb-3">Cat lifestyle</label>
          <div class="flex bg-canvas-soft-2 rounded-pill-sm p-1 gap-1" id="cat-type-options">
            <button class="cat-btn flex-1 text-base font-medium rounded-pill-sm h-12 transition-all duration-200 bg-canvas text-ink shadow-level-1" data-type="indoor">🏠 Indoor</button>
            <button class="cat-btn flex-1 text-base font-medium rounded-pill-sm h-12 transition-all duration-200 text-body hover:text-ink" data-type="outdoor">🌳 Outdoor</button>
          </div>
        </div>

        <!-- Calculate Button -->
        <button
          id="calculate-btn"
          class="w-full flex items-center justify-center bg-primary text-on-primary text-lg font-semibold rounded-pill h-14 mt-4 transition-all duration-200 hover:opacity-90 hover:scale-[1.005] active:scale-[0.99] shadow-level-2 cursor-pointer"
        >
          Calculate age
        </button>
      </div>

      <!-- Results Panel (hidden initially) -->
      <div id="results-panel" class="hidden border-t border-hairline bg-canvas">
        <!-- Result Header -->
        <div class="bg-primary text-on-primary p-6 md:p-8 lg:p-10">
          <span class="caption-mono text-on-primary/60 block mb-2">The results</span>
          <div class="flex items-baseline gap-3 mb-1">
            <span id="result-age" class="display-xl text-on-primary" style="font-size: 64px; line-height: 1;">—</span>
            <span class="body-lg text-on-primary/80">human years</span>
          </div>
          <p id="result-description" class="body-md text-on-primary/70 mt-3"></p>
        </div>

        <!-- Life Stage + Timeline -->
        <div class="p-6 md:p-8 lg:p-10">
          <!-- Life Stage Badge -->
          <div class="flex items-center gap-3 mb-6">
            <span class="body-sm-strong text-body">Life stage:</span>
            <span id="result-stage" class="inline-flex items-center body-sm-strong bg-canvas-soft-2 text-ink rounded-full px-3 py-1"></span>
          </div>

          <!-- Age Timeline Bar -->
          <div class="mb-8 mt-2">
            <div class="flex justify-between body-sm-strong text-ink mb-3 px-1">
              <span id="timeline-pet-label">Puppy</span>
              <span>Senior</span>
            </div>
            
            <div class="relative h-4 bg-canvas-soft shadow-inner rounded-full overflow-hidden border border-hairline flex items-center px-[2px]">
              
              <!-- Background ruler tick marks -->
              <div class="absolute inset-0 flex justify-evenly opacity-20 pointer-events-none">
                <div class="w-px h-full bg-body"></div>
                <div class="w-px h-full bg-body"></div>
                <div class="w-px h-full bg-body"></div>
              </div>
              
              <!-- The Bar Fill -->
              <div 
                id="timeline-bar" 
                class="relative h-3 rounded-full transition-all duration-[1500ms] ease-out flex items-center justify-end shadow-level-2" 
                style="width: 0%; background: linear-gradient(90deg, var(--color-grad-develop-start), var(--color-grad-preview-start), var(--color-grad-preview-end)); background-size: 200% 100%; animation: slide-gradient 3s linear infinite;"
              >
                <!-- Glowing Indicator Dot -->
                <div class="w-2.5 h-2.5 bg-white rounded-full shadow-[0_0_12px_4px_rgba(255,255,255,0.7)] mr-[2px]"></div>
              </div>
            </div>
            
            <div class="flex justify-between caption-mono text-mute mt-3 px-1">
              <span>0 years</span>
              <span id="timeline-max-label">15 years</span>
            </div>
          </div>

          <!-- Health Tips Card -->
          <div class="bg-canvas-soft rounded-md p-5 shadow-level-1">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-lg">💡</span>
              <span class="body-sm-strong text-ink">Health tip for this life stage</span>
            </div>
            <p id="result-tip" class="body-sm text-body"></p>
          </div>

          <!-- Did you know? (Rotating Facts) -->
          <div class="relative overflow-hidden rounded-md p-[1px] mt-6 shadow-level-2 group">
            <div class="absolute inset-0 bg-[linear-gradient(90deg,var(--color-grad-preview-start),var(--color-grad-preview-end),var(--color-grad-preview-start))] bg-[length:200%_100%] animate-[slide-gradient_3s_linear_infinite]"></div>
            <div class="relative bg-canvas p-5 rounded-[5px] h-full flex flex-col justify-center">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-xl animate-pulse">✨</span>
                <span class="caption-mono text-ink">Did you know?</span>
              </div>
              <p id="result-fact" class="body-sm text-body min-h-[40px] transition-all duration-500 transform translate-y-0 opacity-100"></p>
            </div>
          </div>

          <!-- Action Row -->
          <div class="flex flex-col sm:flex-row gap-3 mt-6">
            <button
              id="share-btn"
              class="flex-1 flex items-center justify-center gap-2 body-sm-strong rounded-pill h-10 border border-hairline bg-canvas text-ink hover:border-hairline-strong transition-all cursor-pointer"
            >
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M4 8v5a1 1 0 001 1h6a1 1 0 001-1V8" />
                <polyline points="8 10 8 2" />
                <polyline points="5 5 8 2 11 5" />
              </svg>
              Share result
            </button>
            <button
              id="recalculate-btn"
              class="flex-1 flex items-center justify-center gap-2 body-sm-strong rounded-pill h-10 bg-primary text-on-primary hover:opacity-90 transition-all cursor-pointer"
            >
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M2 8a6 6 0 0111.46-2.46" />
                <path d="M14 8a6 6 0 01-11.46 2.46" />
                <polyline points="14 2 14 6 10 6" />
                <polyline points="2 14 2 10 6 10" />
              </svg>
              Calculate again
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // ─── Age Calculation Engine ───
  const DOG_COEFFICIENTS = {
    toy:    { yearOne: 15, yearTwo: 9, after: 4, maxAge: 18 },
    small:  { yearOne: 15, yearTwo: 9, after: 4, maxAge: 16 },
    medium: { yearOne: 15, yearTwo: 9, after: 5, maxAge: 14 },
    large:  { yearOne: 12, yearTwo: 7, after: 7, maxAge: 12 },
    giant:  { yearOne: 12, yearTwo: 7, after: 8, maxAge: 10 },
  };

  const BREEDS = [
    { name: "Mixed Breed", size: "mixed" },
    { name: "Don't know", size: "mixed" },
    { name: "Afghan Hound", size: "large" },
    { name: "Airedale Terrier", size: "large" },
    { name: "Akita", size: "large" },
    { name: "Alaskan Malamute", size: "large" },
    { name: "American Bulldog", size: "large" },
    { name: "American Eskimo Dog", size: "medium" },
    { name: "American Pit Bull Terrier", size: "large" },
    { name: "American Staffordshire Terrier", size: "medium" },
    { name: "Anatolian Shepherd", size: "giant" },
    { name: "Australian Cattle Dog", size: "medium" },
    { name: "Australian Shepherd", size: "medium" },
    { name: "Basset Hound", size: "medium" },
    { name: "Beagle", size: "medium" },
    { name: "Belgian Malinois", size: "large" },
    { name: "Bernese Mountain Dog", size: "large" },
    { name: "Bichon Frise", size: "small" },
    { name: "Bloodhound", size: "large" },
    { name: "Border Collie", size: "medium" },
    { name: "Border Terrier", size: "small" },
    { name: "Boston Terrier", size: "small" },
    { name: "Boxer", size: "large" },
    { name: "Boykin Spaniel", size: "medium" },
    { name: "Brittany", size: "medium" },
    { name: "Brussels Griffon", size: "toy" },
    { name: "Bull Terrier", size: "medium" },
    { name: "Bulldog", size: "medium" },
    { name: "Bullmastiff", size: "giant" },
    { name: "Cairn Terrier", size: "small" },
    { name: "Cane Corso", size: "giant" },
    { name: "Cardigan Welsh Corgi", size: "medium" },
    { name: "Cavalier King Charles Spaniel", size: "small" },
    { name: "Chesapeake Bay Retriever", size: "large" },
    { name: "Chihuahua", size: "toy" },
    { name: "Chinese Crested", size: "toy" },
    { name: "Chinese Shar-Pei", size: "medium" },
    { name: "Chow Chow", size: "medium" },
    { name: "Cocker Spaniel", size: "medium" },
    { name: "Collie", size: "large" },
    { name: "Coton de Tulear", size: "small" },
    { name: "Dachshund", size: "small" },
    { name: "Dalmatian", size: "large" },
    { name: "Doberman Pinscher", size: "large" },
    { name: "Dogo Argentino", size: "large" },
    { name: "English Cocker Spaniel", size: "medium" },
    { name: "English Setter", size: "large" },
    { name: "English Springer Spaniel", size: "medium" },
    { name: "French Bulldog", size: "small" },
    { name: "German Shepherd", size: "large" },
    { name: "German Shorthaired Pointer", size: "large" },
    { name: "Giant Schnauzer", size: "large" },
    { name: "Golden Retriever", size: "large" },
    { name: "Gordon Setter", size: "large" },
    { name: "Great Dane", size: "giant" },
    { name: "Great Pyrenees", size: "giant" },
    { name: "Greyhound", size: "large" },
    { name: "Havanese", size: "small" },
    { name: "Irish Setter", size: "large" },
    { name: "Irish Wolfhound", size: "giant" },
    { name: "Italian Greyhound", size: "toy" },
    { name: "Jack Russell Terrier", size: "small" },
    { name: "Japanese Chin", size: "toy" },
    { name: "Keeshond", size: "medium" },
    { name: "Labrador Retriever", size: "large" },
    { name: "Lhasa Apso", size: "small" },
    { name: "Maltese", size: "toy" },
    { name: "Mastiff", size: "giant" },
    { name: "Miniature Pinscher", size: "toy" },
    { name: "Miniature Poodle", size: "small" },
    { name: "Miniature Schnauzer", size: "small" },
    { name: "Newfoundland", size: "giant" },
    { name: "Papillon", size: "toy" },
    { name: "Pekingese", size: "toy" },
    { name: "Pembroke Welsh Corgi", size: "medium" },
    { name: "Pit Bull Terrier", size: "large" },
    { name: "Pointer", size: "large" },
    { name: "Pomeranian", size: "toy" },
    { name: "Pug", size: "small" },
    { name: "Rat Terrier", size: "small" },
    { name: "Rhodesian Ridgeback", size: "large" },
    { name: "Rottweiler", size: "large" },
    { name: "Saint Bernard", size: "giant" },
    { name: "Samoyed", size: "large" },
    { name: "Scottish Terrier", size: "small" },
    { name: "Shetland Sheepdog", size: "small" },
    { name: "Shiba Inu", size: "medium" },
    { name: "Shih Tzu", size: "small" },
    { name: "Siberian Husky", size: "large" },
    { name: "Silky Terrier", size: "toy" },
    { name: "Soft Coated Wheaten Terrier", size: "medium" },
    { name: "Staffordshire Bull Terrier", size: "medium" },
    { name: "Standard Poodle", size: "large" },
    { name: "Standard Schnauzer", size: "medium" },
    { name: "Tibetan Terrier", size: "medium" },
    { name: "Toy Poodle", size: "toy" },
    { name: "Vizsla", size: "large" },
    { name: "Weimaraner", size: "large" },
    { name: "West Highland White Terrier", size: "small" },
    { name: "Whippet", size: "medium" },
    { name: "Wirehaired Pointing Griffon", size: "large" },
    { name: "Yorkshire Terrier", size: "toy" }
  ];

  const CAT_COEFFICIENTS = {
    indoor:  { yearOne: 15, yearTwo: 9, after: 4, maxAge: 20 },
    outdoor: { yearOne: 15, yearTwo: 9, after: 5, maxAge: 16 },
  };

  const LIFE_STAGES: Record<string, { label: string; emoji: string }> = {
    puppy:    { label: 'Puppy',     emoji: '🐶' },
    kitten:   { label: 'Kitten',    emoji: '🐱' },
    junior:   { label: 'Junior',    emoji: '🧒' },
    adult:    { label: 'Adult',     emoji: '👤' },
    mature:   { label: 'Mature',    emoji: '🧑' },
    senior:   { label: 'Senior',    emoji: '👴' },
    geriatric:{ label: 'Geriatric', emoji: '🏥' },
  };

  const HEALTH_TIPS: Record<string, string> = {
    puppy: "Focus on socialization and establishing a vaccination schedule. Puppies need frequent, smaller meals and lots of positive reinforcement training.",
    kitten: "Kittens need frequent meals, regular vet visits for vaccinations, and lots of interactive play for proper development and socialization.",
    junior: "Your pet is an energetic teenager! Maintain regular exercise routines, continue training, and ensure a balanced diet for healthy growth.",
    adult: "Keep up with annual vet check-ups, maintain a healthy weight through proper diet and exercise, and watch for any behavioral changes.",
    mature: "Consider switching to a senior-formula diet. Bi-annual vet visits are recommended. Watch for signs of arthritis or weight changes.",
    senior: "Regular blood work and dental care become crucial. Provide joint supplements if recommended, and adapt exercise to their comfort level.",
    geriatric: "Focus on comfort and quality of life. More frequent vet visits, pain management, and gentle daily activity. Keep their environment accessible.",
  };

  function calculateHumanAge(petYears: number, petMonths: number, coefficients: { yearOne: number; yearTwo: number; after: number }) {
    const totalAge = petYears + petMonths / 12;
    if (totalAge <= 0) return 0;
    if (totalAge <= 1) return Math.round(totalAge * coefficients.yearOne);
    if (totalAge <= 2) return Math.round(coefficients.yearOne + (totalAge - 1) * coefficients.yearTwo);
    return Math.round(coefficients.yearOne + coefficients.yearTwo + (totalAge - 2) * coefficients.after);
  }

  function getLifeStage(petType: string, humanAge: number): string {
    if (petType === 'dog') {
      if (humanAge <= 15) return 'puppy';
      if (humanAge <= 24) return 'junior';
      if (humanAge <= 50) return 'adult';
      if (humanAge <= 75) return 'mature';
      if (humanAge <= 90) return 'senior';
      return 'geriatric';
    } else {
      if (humanAge <= 15) return 'kitten';
      if (humanAge <= 24) return 'junior';
      if (humanAge <= 48) return 'adult';
      if (humanAge <= 72) return 'mature';
      if (humanAge <= 90) return 'senior';
      return 'geriatric';
    }
  }

  // ─── DOM Elements & Initialization ───
  const wrapper = document.getElementById('calculator-card')!;
  const calcType = wrapper.dataset.type || 'both';
  
  let currentPet = calcType === 'cat' ? 'cat' : 'dog';
  let currentDogSize = 'small';
  let currentCatType = 'indoor';

  const petTabs = document.querySelectorAll('.pet-tab') as NodeListOf<HTMLButtonElement>;
  const dogSizeGroup = document.getElementById('dog-size-group')!;
  const catTypeGroup = document.getElementById('cat-type-group')!;
  const sizeBtns = document.querySelectorAll('.size-btn') as NodeListOf<HTMLButtonElement>;
  const catBtns = document.querySelectorAll('.cat-btn') as NodeListOf<HTMLButtonElement>;
  const calculateBtn = document.getElementById('calculate-btn')!;
  const resultsPanel = document.getElementById('results-panel')!;
  const resultAge = document.getElementById('result-age')!;
  const resultDesc = document.getElementById('result-description')!;
  const resultStage = document.getElementById('result-stage')!;
  const timelineBar = document.getElementById('timeline-bar')! as HTMLElement;
  const timelinePetLabel = document.getElementById('timeline-pet-label')!;
  const timelineMaxLabel = document.getElementById('timeline-max-label')!;
  const resultTip = document.getElementById('result-tip')!;
  const shareBtn = document.getElementById('share-btn')!;
  const recalculateBtn = document.getElementById('recalculate-btn')!;
  const yearsInput = document.getElementById('age-years') as HTMLInputElement;
  const monthsSelect = document.getElementById('age-months') as HTMLSelectElement;

  // ─── Pet Type Toggle ───
  petTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      currentPet = tab.dataset.pet || 'dog';
      petTabs.forEach(t => {
        const isActive = t === tab;
        t.setAttribute('aria-selected', String(isActive));
        t.className = t.className
          .replace(/bg-canvas text-ink shadow-level-1|text-body hover:text-ink/g, '')
          .trim();
        t.classList.add(...(isActive
          ? ['bg-canvas', 'text-ink', 'shadow-level-1']
          : ['text-body', 'hover:text-ink']));
      });
      dogSizeGroup.classList.toggle('hidden', currentPet !== 'dog');
      catTypeGroup.classList.toggle('hidden', currentPet !== 'cat');
      yearsInput.max = currentPet === 'dog' ? '25' : '30';
    });
  });

  // ─── Breed Selector Logic ───
  const breedSearch = document.getElementById('breed-search') as HTMLInputElement;
  const breedDropdown = document.getElementById('breed-dropdown')!;
  const breedClear = document.getElementById('breed-clear')!;
  const dogSizeFallback = document.getElementById('dog-size-fallback')!;

  function renderBreeds(filter = '') {
    const q = filter.toLowerCase();
    const filtered = BREEDS.filter(b => b.name.toLowerCase().includes(q));
    
    if (filtered.length === 0) {
      breedDropdown.innerHTML = `<li class="p-3 text-mute body-sm">No breeds found. Try "Mixed Breed"</li>`;
      return;
    }
    
    breedDropdown.innerHTML = filtered.map(b => 
      `<li class="p-3 body-sm text-ink hover:bg-canvas-soft cursor-pointer transition-colors" data-name="${b.name}" data-size="${b.size}">${b.name}</li>`
    ).join('');
    
    // Attach clicks to new list items
    breedDropdown.querySelectorAll('li[data-name]').forEach(li => {
      li.addEventListener('click', () => {
        const name = (li as HTMLElement).dataset.name!;
        const size = (li as HTMLElement).dataset.size!;
        breedSearch.value = name;
        breedDropdown.classList.add('hidden');
        breedClear.classList.remove('hidden');
        
        if (size === 'mixed') {
          // Reveal fallback size options
          dogSizeFallback.classList.remove('hidden');
          // Select default small
          const defaultBtn = document.querySelector('.size-btn[data-size="small"]') as HTMLButtonElement;
          defaultBtn?.click();
        } else {
          // Hide fallback size options and set the size silently
          dogSizeFallback.classList.add('hidden');
          const targetBtn = document.querySelector(`.size-btn[data-size="${size}"]`) as HTMLButtonElement;
          targetBtn?.click();
        }
      });
    });
  }

  if (breedSearch) {
    breedSearch.addEventListener('focus', () => {
      breedDropdown.classList.remove('hidden');
      renderBreeds(breedSearch.value);
    });

    breedSearch.addEventListener('input', (e) => {
      const val = (e.target as HTMLInputElement).value;
      breedClear.classList.toggle('hidden', val.length === 0);
      breedDropdown.classList.remove('hidden');
      renderBreeds(val);
    });

    breedClear.addEventListener('click', () => {
      breedSearch.value = '';
      breedClear.classList.add('hidden');
      breedDropdown.classList.add('hidden');
      // Default back to showing size options and "small"
      dogSizeFallback.classList.remove('hidden');
      const defaultBtn = document.querySelector('.size-btn[data-size="small"]') as HTMLButtonElement;
      defaultBtn?.click();
      breedSearch.focus();
    });

    document.addEventListener('click', (e) => {
      if (!document.getElementById('breed-selector-group')?.contains(e.target as Node)) {
        breedDropdown.classList.add('hidden');
      }
    });
  }

  // ─── Dog Size Selection ───
  sizeBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      currentDogSize = btn.dataset.size || 'small';
      sizeBtns.forEach(b => {
        b.classList.remove('bg-primary', 'text-on-primary', 'border-primary');
        b.classList.add('bg-canvas', 'text-body', 'border-hairline');
      });
      btn.classList.remove('bg-canvas', 'text-body', 'border-hairline');
      btn.classList.add('bg-primary', 'text-on-primary', 'border-primary');
    });
  });

  // ─── Cat Type Selection ───
  catBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      currentCatType = btn.dataset.type || 'indoor';
      catBtns.forEach(b => {
        b.className = b.className
          .replace(/bg-canvas text-ink shadow-level-1|text-body hover:text-ink/g, '')
          .trim();
        b.classList.add(...(b === btn
          ? ['bg-canvas', 'text-ink', 'shadow-level-1']
          : ['text-body', 'hover:text-ink']));
      });
    });
  });

  // ─── Calculate ───
  function runCalculation() {
    const years = parseInt(yearsInput.value) || 0;
    const months = parseInt(monthsSelect.value) || 0;
    const totalAge = years + months / 12;

    const coefficients = currentPet === 'dog'
      ? DOG_COEFFICIENTS[currentDogSize as keyof typeof DOG_COEFFICIENTS]
      : CAT_COEFFICIENTS[currentCatType as keyof typeof CAT_COEFFICIENTS];

    const humanAge = calculateHumanAge(years, months, coefficients);
    const stage = getLifeStage(currentPet, humanAge);
    const stageInfo = LIFE_STAGES[stage];
    const maxAge = coefficients.maxAge;
    const timelinePercent = Math.min((totalAge / maxAge) * 100, 100);

    // Update results
    resultAge.textContent = String(humanAge);
    resultDesc.textContent = `Your ${currentPet === 'dog' ? 'dog' : 'cat'} is equivalent to a ${humanAge}-year-old human.`;
    resultStage.textContent = `${stageInfo.emoji} ${stageInfo.label}`;
    timelinePetLabel.textContent = currentPet === 'dog' ? 'Puppy' : 'Kitten';
    timelineMaxLabel.textContent = `${maxAge} years`;
    resultTip.textContent = HEALTH_TIPS[stage] || HEALTH_TIPS['adult'];

    // Show results
    resultsPanel.classList.remove('hidden');
    
    // Animate timeline bar
    requestAnimationFrame(() => {
      timelineBar.style.width = `${timelinePercent}%`;
    });

    // Start rotating facts
    startFacts();

    // Scroll to results
    resultsPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // ─── Facts Logic ───
  const FACTS = {
    dog: [
      "A dog's sense of smell is 10,000 to 100,000 times more sensitive than ours!",
      "Dogs can learn over 100 words and gestures.",
      "Your dog's nose print is as unique as a human fingerprint.",
      "Greyhounds can run up to 45 miles per hour.",
      "Dogs have three eyelids to protect their eyes."
    ],
    cat: [
      "Cats spend 70% of their lives sleeping.",
      "A cat's purr has been shown to improve bone density.",
      "Cats can rotate their ears 180 degrees.",
      "A cat's nose print is completely unique, just like a human fingerprint.",
      "Cats don't have collarbones, allowing them to fit through tight spaces."
    ]
  };

  let factInterval: ReturnType<typeof setInterval>;
  const resultFactEl = document.getElementById('result-fact')!;

  function startFacts() {
    clearInterval(factInterval);
    const petFacts = FACTS[currentPet as keyof typeof FACTS];
    let index = Math.floor(Math.random() * petFacts.length);
    
    // Initial fact
    resultFactEl.textContent = petFacts[index];
    resultFactEl.style.opacity = '1';
    resultFactEl.style.transform = 'translateY(0)';

    // Rotate every 5 seconds
    factInterval = setInterval(() => {
      // Slide up and fade out
      resultFactEl.style.opacity = '0';
      resultFactEl.style.transform = 'translateY(-10px)';
      
      setTimeout(() => {
        // Change text
        index = (index + 1) % petFacts.length;
        resultFactEl.textContent = petFacts[index];
        
        // Reset position to bottom instantly without transition
        resultFactEl.style.transition = 'none';
        resultFactEl.style.transform = 'translateY(10px)';
        
        // Trigger reflow to apply the un-transitioned state
        void resultFactEl.offsetWidth;
        
        // Restore transition, slide to middle and fade in
        resultFactEl.style.transition = 'all 0.5s ease';
        resultFactEl.style.opacity = '1';
        resultFactEl.style.transform = 'translateY(0)';
      }, 500); // Wait for fade out
    }, 5000);
  }

  function stopFacts() {
    clearInterval(factInterval);
  }

  calculateBtn.addEventListener('click', runCalculation);

  // ─── Recalculate ───
  recalculateBtn.addEventListener('click', () => {
    resultsPanel.classList.add('hidden');
    timelineBar.style.width = '0%';
    stopFacts();
    document.getElementById('calculator')?.scrollIntoView({ behavior: 'smooth' });
  });

  // ─── Share ───
  shareBtn.addEventListener('click', async () => {
    const years = yearsInput.value;
    const months = monthsSelect.value;
    const humanAge = resultAge.textContent;
    const stage = resultStage.textContent;
    const petType = currentPet === 'dog' ? 'dog' : 'cat';

    const text = `🐾 My ${petType} is ${years} years and ${months} months old — that's ${humanAge} human years! (${stage})\n\nFind out your pet's age: https://mypetagecalc.com`;

    if (navigator.share) {
      try {
        await navigator.share({ title: 'Pet Age Calculator', text });
      } catch {}
    } else {
      await navigator.clipboard.writeText(text);
      const original = shareBtn.innerHTML;
      shareBtn.innerHTML = `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="4 8 7 11 12 5"></polyline></svg> Copied!`;
      setTimeout(() => { shareBtn.innerHTML = original; }, 2000);
    }
  });

  // ─── Keyboard: Enter to calculate ───
  yearsInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') runCalculation(); });
  monthsSelect.addEventListener('keydown', (e) => { if (e.key === 'Enter') runCalculation(); });
</script>
