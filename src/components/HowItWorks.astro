---
interface Props {
  type?: 'dog' | 'cat' | 'both';
}

const { type = 'both' } = Astro.props;
const isDogOnly = type === 'dog';
const isCatOnly = type === 'cat';
---

<section id="how-it-works" class="bg-primary text-on-primary py-20 md:py-28">
  <div class="page-container">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <span class="caption-mono text-on-primary/50 block mb-3">How it works</span>
      <h2 class="display-lg display-lg-responsive text-on-primary max-w-[600px] mx-auto">
        {type === 'dog' ? 'Not all dogs age the same.' : type === 'cat' ? 'Not all cats age the same.' : 'Not all pets age the same.'}
      </h2>
      <p class="body-lg text-on-primary/70 mt-4 max-w-[500px] mx-auto">
        The old "7 years" myth is wrong. Here's why our calculator is more accurate.
      </p>
    </div>

    <!-- 3-up card grid (or 2-up depending on type) -->
    <div class={`grid grid-cols-1 ${type === 'both' ? 'md:grid-cols-3' : 'md:grid-cols-2'} gap-6 max-w-[1000px] mx-auto`}>
      
      <!-- Card 1: Size Matters (Dogs only or Both) -->
      {!isCatOnly && (
        <div class="bg-on-primary/5 backdrop-blur-sm rounded-md p-6 border border-on-primary/10 transition-all duration-300 hover:bg-on-primary/10 hover:border-on-primary/20 group">
          <div class="w-12 h-12 rounded-md bg-on-primary/10 flex items-center justify-center mb-5 text-2xl group-hover:scale-110 transition-transform duration-300">
            📏
          </div>
          <h3 class="display-sm text-on-primary mb-3">Size matters.</h3>
          <p class="body-sm text-on-primary/70">
            A Great Dane ages much faster than a Chihuahua. Large dogs reach "senior" status at 6-7 years, while small dogs may not until 10-11 years. Our calculator accounts for five distinct size categories.
          </p>
        </div>
      )}

      <!-- Card 2: The First Year Myth (All) -->
      <div class="bg-on-primary/5 backdrop-blur-sm rounded-md p-6 border border-on-primary/10 transition-all duration-300 hover:bg-on-primary/10 hover:border-on-primary/20 group">
        <div class="w-12 h-12 rounded-md bg-on-primary/10 flex items-center justify-center mb-5 text-2xl group-hover:scale-110 transition-transform duration-300">
          🧮
        </div>
        <h3 class="display-sm text-on-primary mb-3">The first year myth.</h3>
        <p class="body-sm text-on-primary/70">
          A 1-year-old {type === 'dog' ? 'dog' : type === 'cat' ? 'cat' : 'pet'} isn't 7 in human years — they're closer to 15. {type === 'both' ? 'Pets' : type === 'dog' ? 'Dogs' : 'Cats'} age rapidly in their first two years, then slow down. Our non-linear formula matches veterinary research.
        </p>
      </div>

      <!-- Card 3: Indoor vs Outdoor (Cats only or Both) -->
      {!isDogOnly && (
        <div class="bg-on-primary/5 backdrop-blur-sm rounded-md p-6 border border-on-primary/10 transition-all duration-300 hover:bg-on-primary/10 hover:border-on-primary/20 group">
          <div class="w-12 h-12 rounded-md bg-on-primary/10 flex items-center justify-center mb-5 text-2xl group-hover:scale-110 transition-transform duration-300">
            🏠
          </div>
          <h3 class="display-sm text-on-primary mb-3">Indoor vs outdoor.</h3>
          <p class="body-sm text-on-primary/70">
            Indoor cats live significantly longer than outdoor cats — up to 20 years versus 12-14. Environment affects aging rate, and our calculator adjusts for this lifestyle difference.
          </p>
        </div>
      )}
    </div>
  </div>
</section>
